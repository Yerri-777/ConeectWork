<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="ReporteCancelaciones" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <parameter name="totalReembolsado" class="java.lang.Double"/>

    <field name="numero" class="java.lang.String"/>
    <field name="cliente" class="java.lang.String"/>
    <field name="reembolso" class="java.lang.Double"/>
    <field name="fechaOperacion" class="java.lang.String"/>

    <title>
        <band height="70">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[BITÁCORA DE REEMBOLSOS Y CANCELACIONES]]></text>
            </staticText>
            <textField pattern="MMMMM dd, yyyy">
                <reportElement x="450" y="40" width="100" height="20"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="30" backcolor="#E67E22"/>
            </rectangle>
            <staticText>
                <reportElement x="10" y="5" width="100" height="20" forecolor="#FFFFFF"/>
                <text><![CDATA[Reserva]]></text>
            </staticText>
            <staticText>
                <reportElement x="120" y="5" width="200" height="20" forecolor="#FFFFFF"/>
                <text><![CDATA[Cliente Titular]]></text>
            </staticText>
            <staticText>
                <reportElement x="330" y="5" width="100" height="20" forecolor="#FFFFFF"/>
                <text><![CDATA[Fecha Op.]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="5" width="100" height="20" forecolor="#FFFFFF"/>
                <text><![CDATA[Monto Devuelto]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25">
            <textField>
                <reportElement x="10" y="5" width="100" height="15"/>
                <textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="5" width="200" height="15"/>
                <textFieldExpression><![CDATA[$F{cliente}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="330" y="5" width="100" height="15"/>
                <textFieldExpression><![CDATA[$F{fechaOperacion}]]></textFieldExpression>
            </textField>
            <textField pattern="Q #,##0.00">
                <reportElement x="440" y="5" width="100" height="15" forecolor="#C0392B"/>
                <textFieldExpression><![CDATA[$F{reembolso}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="50">
            <staticText>
                <reportElement x="330" y="20" width="110" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL EGRESOS: ]]></text>
            </staticText>
            <textField pattern="Q #,##0.00">
                <reportElement x="445" y="20" width="100" height="20" forecolor="#C0392B"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalReembolsado}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>