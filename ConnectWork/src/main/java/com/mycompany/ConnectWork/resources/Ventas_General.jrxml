<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="ReporteVentas" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
    
    <parameter name="totalVentas" class="java.lang.Double"/>
    <parameter name="costosTotales" class="java.lang.Double"/>
    <parameter name="gananciaNeta" class="java.lang.Double"/>

    <queryString>
        <![CDATA[]]>
    </queryString>

    <field name="numero" class="java.lang.String"/>
    <field name="cliente" class="java.lang.String"/>
    <field name="paquete" class="java.lang.String"/>
    <field name="costo" class="java.lang.Double"/>

    <title>
        <band height="79" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="79" backcolor="#1A1A1A"/>
            </rectangle>
            <staticText>
                <reportElement x="20" y="20" width="300" height="30" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[HORIZONTES SIN LÍMITES]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="50" width="200" height="20" forecolor="#3498DB"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[REPORTE FINANCIERO DE VENTAS]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="30" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="100" height="30"/>
                <text><![CDATA[Código]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="0" width="150" height="30"/>
                <text><![CDATA[Cliente]]></text>
            </staticText>
            <staticText>
                <reportElement x="250" y="0" width="200" height="30"/>
                <text><![CDATA[Paquete Turístico]]></text>
            </staticText>
            <staticText>
                <reportElement x="450" y="0" width="105" height="30"/>
                <text><![CDATA[Monto (Q)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25" splitType="Stretch">
            <textField>
                <reportElement x="0" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="100" y="0" width="150" height="20"/>
                <textFieldExpression><![CDATA[$F{cliente}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="250" y="0" width="200" height="20"/>
                <textFieldExpression><![CDATA[$F{paquete}]]></textFieldExpression>
            </textField>
            <textField pattern="Q #,##0.00">
                <reportElement x="450" y="0" width="105" height="20"/>
                <textFieldExpression><![CDATA[$F{costo}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="100">
            <line>
                <reportElement x="0" y="10" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="350" y="20" width="100" height="20"/>
                <text><![CDATA[Total Ventas:]]></text>
            </staticText>
            <textField pattern="Q #,##0.00">
                <reportElement x="450" y="20" width="105" height="20"/>
                <textFieldExpression><![CDATA[$P{totalVentas}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="350" y="60" width="100" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[UTILIDAD NETA:]]></text>
            </staticText>
            <textField pattern="Q #,##0.00">
                <reportElement x="450" y="60" width="105" height="20" forecolor="#27AE60"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{gananciaNeta}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>